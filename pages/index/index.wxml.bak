<!-- pages/index/index.wxml -->
<view class="page-container">
  <!-- 顶部状态卡片 -->
  <view class="header-card">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="user-info">
        <view class="avatar-wrapper">
          <view class="avatar">
            <text class="avatar-text">医</text>
          </view>
          <view class="user-text">
            <text class="welcome-text">欢迎使用</text>
            <text class="app-name">简医记</text>
          </view>
        </view>
        <view class="record-badge" wx:if="{{recordCount > 0}}">
          <text class="badge-num">{{recordCount}}</text>
          <text class="badge-text">条记录</text>
        </view>
      </view>
      
      <!-- 动态消息提示 -->
      <view class="message-card" wx:if="{{message}}">
        <view class="message-icon">💡</view>
        <text class="message-text">{{message}}</text>
      </view>
    </view>
  </view>

  <!-- 快捷功能入口 - 宫格布局 -->
  <view class="section">
    <view class="section-title">
      <text class="title-text">快捷功能</text>
    </view>
    <view class="feature-grid">
      <view class="feature-item feature-scan" bindtap="chooseImage">
        <view class="feature-icon-wrapper">
          <text class="feature-icon">📷</text>
        </view>
        <text class="feature-name">拍照录入</text>
        <text class="feature-desc">智能识别化验单</text>
      </view>
      
      <view class="feature-item feature-input" bindtap="handleInputClick">
        <view class="feature-icon-wrapper">
          <text class="feature-icon">✏️</text>
        </view>
        <text class="feature-name">手工录入</text>
        <text class="feature-desc">血压、身高体重等</text>
      </view>
      
      <view class="feature-item feature-query" bindtap="handleQueryClick">
        <view class="feature-icon-wrapper">
          <text class="feature-icon">📋</text>
        </view>
        <text class="feature-name">历史查询</text>
        <text class="feature-desc">查看过往记录</text>
      </view>
      
      <view class="feature-item feature-analysis" bindtap="handleStatisticsClick">
        <view class="feature-icon-wrapper">
          <text class="feature-icon">📊</text>
        </view>
        <text class="feature-name">趋势分析</text>
        <text class="feature-desc">数据可视化统计</text>
      </view>
    </view>
  </view>

  <!-- 最近记录预览 -->
  <view class="section" wx:if="{{recentRecords.length > 0}}">
    <view class="section-title">
      <text class="title-text">最近记录</text>
      <text class="more-link" bindtap="handleQueryClick">查看全部 ></text>
    </view>
    <view class="record-list">
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-cate="{{item.cate_id}}">
        <view class="record-type-tag" style="background: {{item.color}}">{{item.type}}</view>
        <view class="record-info">
          <text class="record-date">{{item.date}}</text>
          <text class="record-hospital">{{item.hospital}}</text>
        </view>
        <text class="record-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 空状态提示 -->
  <view class="empty-state" wx:if="{{recordCount === 0 && !loading}}">
    <view class="empty-icon">📝</view>
    <text class="empty-title">还没有记录</text>
    <text class="empty-desc">点击下方按钮录入您的第一份健康数据</text>
    <view class="empty-action" bindtap="chooseImage">
      <text>立即录入</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 底部版权 -->
  <view class="footer">
    <navigator class="footer-link" url="/pages/about/about">关于简医记 V1.5</navigator>
    <text class="footer-text">Copyright © 2025 学登科技</text>
  </view>
</view>
