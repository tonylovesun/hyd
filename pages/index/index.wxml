<!-- pages/index/index.wxml - 极简风格首页 -->
<view class="page-container">
  <!-- 极简顶部导航 -->
  <view class="nav-bar">
    <text class="nav-title">简医记</text>
    <view class="nav-menu" bindtap="handleMenuClick">
      <text>☰</text>
    </view>
  </view>

  <!-- 主操作区域 -->
  <view class="main-action">
    <!-- 核心拍照按钮 -->
    <view class="primary-btn" bindtap="chooseImage">
      <view class="primary-btn-inner">
        <text class="primary-icon">📷</text>
        <text class="primary-text">拍照录入</text>
        <text class="primary-desc">智能识别，化验单秒入库</text>
      </view>
    </view>

    <!-- 分隔线 -->
    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或</text>
      <view class="divider-line"></view>
    </view>

    <!-- 次级操作 -->
    <view class="secondary-btn" bindtap="handleInputClick">
      <text class="secondary-icon">✏️</text>
      <text class="secondary-text">手工录入</text>
    </view>
  </view>

  <!-- 历史记录区 -->
  <view class="record-section">
    <view class="section-header">
      <text class="section-title">历史记录</text>
      <text class="section-count" wx:if="{{recordCount > 0}}">共 {{recordCount}} 条</text>
    </view>

    <!-- 记录列表 -->
    <view class="record-list" wx:if="{{recentRecords.length > 0}}">
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-cate="{{item.cate_id}}">
        <view class="record-left">
          <view class="record-type-dot" style="background: {{item.color}}"></view>
          <view class="record-info">
            <text class="record-type">{{item.type}}</text>
            <text class="record-meta">{{item.hospital}} · {{item.date}}</text>
          </view>
        </view>
        <text class="record-arrow">›</text>
      </view>
      
      <!-- 查看全部 -->
      <view class="view-more" bindtap="handleQueryClick">
        <text>查看全部记录</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{recentRecords.length === 0 && !loading}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无记录</text>
      <text class="empty-hint">点击上方按钮开始录入</text>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading && recentRecords.length === 0}}">
      <view class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>
  </view>

  <!-- 底部工具栏 -->
  <view class="bottom-toolbar">
    <view class="tool-btn" bindtap="handleStatisticsClick">
      <text class="tool-btn-icon">📊</text>
      <text class="tool-btn-text">趋势分析</text>
    </view>
    <view class="tool-btn tool-btn-primary" bindtap="handleQueryClick">
      <text class="tool-btn-icon">🔍</text>
      <text class="tool-btn-text">历史查询</text>
    </view>
    <view class="tool-btn" bindtap="handleAboutClick">
      <text class="tool-btn-icon">ℹ️</text>
      <text class="tool-btn-text">关于</text>
    </view>
  </view>
</view>
