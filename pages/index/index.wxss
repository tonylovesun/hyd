/* pages/index/index.wxss - 极简风格首页 */

/* ========== 页面基础 ========== */
.page-container {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 140rpx;
  display: flex;
  flex-direction: column;
}

/* ========== 极简导航栏 ========== */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 2rpx;
}

.nav-menu {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-menu text {
  font-size: 40rpx;
  color: #666;
}

/* ========== 主操作区域 ========== */
.main-action {
  padding: 60rpx 40rpx 40rpx;
  background: #fff;
}

/* 主按钮 */
.primary-btn {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(7, 193, 96, 0.25);
  transition: transform 0.2s, box-shadow 0.2s;
}

.primary-btn:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 30rpx rgba(7, 193, 96, 0.2);
}

.primary-btn-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.primary-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.primary-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.primary-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 0;
  gap: 24rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e5e5e5;
}

.divider-text {
  font-size: 26rpx;
  color: #999;
}

/* 次级按钮 */
.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  transition: background 0.2s;
}

.secondary-btn:active {
  background: #eeeeee;
}

.secondary-icon {
  font-size: 36rpx;
}

.secondary-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* ========== 历史记录区 ========== */
.record-section {
  flex: 1;
  padding: 32rpx 32rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-count {
  font-size: 26rpx;
  color: #999;
}

/* 记录列表 */
.record-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}

.record-item:last-of-type {
  border-bottom: none;
}

.record-item:active {
  background: #fafafa;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.record-type-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-type {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.record-meta {
  font-size: 24rpx;
  color: #999;
}

.record-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 16rpx;
}

/* 查看更多 */
.view-more {
  padding: 28rpx;
  text-align: center;
  border-top: 1rpx solid #f0f0f0;
  transition: background 0.15s;
}

.view-more:active {
  background: #fafafa;
}

.view-more text {
  font-size: 28rpx;
  color: #07c160;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 60rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ccc;
  animation: dot-bounce 1.4s ease-in-out infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dot-bounce {
  0%, 80%, 100% {
    transform: scale(1);
    opacity: 0.5;
  }
  40% {
    transform: scale(1.3);
    opacity: 1;
  }
}

/* ========== 底部工具栏 ========== */
.bottom-toolbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.03);
}

/* 工具按钮基础样式 */
.tool-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: #f7f7f7;
  border-radius: 40rpx;
  transition: all 0.2s;
}

.tool-btn:active {
  transform: scale(0.96);
  opacity: 0.8;
}

.tool-btn-icon {
  font-size: 32rpx;
}

.tool-btn-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

/* 主要按钮样式（历史查询） */
.tool-btn-primary {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.25);
}

.tool-btn-primary:active {
  box-shadow: 0 4rpx 15rpx rgba(7, 193, 96, 0.2);
}

.tool-btn-primary .tool-btn-text {
  color: #fff;
}

/* ========== 拍照指导提示 ========== */
.camera-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.tips-icon {
  font-size: 28rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #92400e;
  line-height: 1.4;
}

/* ========== 图片预览弹窗 ========== */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.preview-content {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.preview-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.preview-image {
  width: 100%;
  height: 500rpx;
  background: #f5f5f5;
}

.preview-tips {
  padding: 20rpx 30rpx;
  background: #fffbeb;
  text-align: center;
}

.preview-tips text {
  font-size: 24rpx;
  color: #b45309;
}

.preview-actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.preview-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin: 0;
}

.preview-btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.preview-btn-confirm {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
}
